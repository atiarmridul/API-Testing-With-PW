#!/usr/bin/env bash
set -euo pipefail

MSG_FILE="${1:-}"

if [ -z "$MSG_FILE" ] || [ ! -f "$MSG_FILE" ]; then
  echo "commit-msg hook: commit message file is missing."
  exit 1
fi

# Skip merge commits.
if grep -qE '^Merge ' "$MSG_FILE"; then
  exit 0
fi

if ! git diff --cached --quiet --exit-code; then
  :
else
  exit 0
fi

CHANGE_BULLETS=""
BODY_BULLETS=""

if grep -q '^Changes:$' "$MSG_FILE"; then
  CHANGE_BULLETS="$(awk '
  BEGIN { in_changes = 0 }
  $0 == "Changes:" { in_changes = 1; next }
  in_changes == 1 && $0 ~ /^- / { print; next }
  in_changes == 1 && $0 !~ /^- / && $0 !~ /^[[:space:]]*$/ { in_changes = 0 }
  ' "$MSG_FILE")"
else
  BODY_BULLETS="$(awk '
  NR > 1 && $0 ~ /^- / { print }
  ' "$MSG_FILE")"
fi

VALID_BULLETS="$CHANGE_BULLETS"
if [ -z "$VALID_BULLETS" ]; then
  VALID_BULLETS="$BODY_BULLETS"
fi

if [ -z "$VALID_BULLETS" ]; then
  echo "Commit message must include descriptive bullet items (with or without a 'Changes:' header)."
  exit 1
fi

if printf '%s\n' "$VALID_BULLETS" | grep -Eq '^- [ACDMRTUXB][0-9]*[[:space:]]+'; then
  echo "Commit blocked: describe what changed instead of listing raw git status/file entries."
  exit 1
fi
