#!/usr/bin/env bash
set -euo pipefail

MSG_FILE="${1:-}"
SOURCE="${2:-}"

if [ -z "$MSG_FILE" ] || [ ! -f "$MSG_FILE" ]; then
  exit 0
fi

# Avoid mutating auto-generated merge/squash commit messages.
case "$SOURCE" in
  merge|squash)
    exit 0
    ;;
esac

# Do not alter explicit CLI-provided messages (-m / -F).
if [ "$SOURCE" = "message" ]; then
  exit 0
fi

# If the message already contains bullets, preserve the author's format.
if awk 'NR > 1 && $0 !~ /^#/ && $0 ~ /^- / { found = 1 } END { exit(found ? 0 : 1) }' "$MSG_FILE"; then
  exit 0
fi

# Skip template insertion if nothing is staged.
if git diff --cached --quiet --exit-code; then
  exit 0
fi

{
  echo
  echo "Changes:"
  echo "- "
  echo "- "
} >> "$MSG_FILE"
